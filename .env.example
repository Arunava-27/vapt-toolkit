# VAPT Toolkit Configuration Example
# For Docker deployment, see docs/DOCKER_DEPLOYMENT.md

# ──────────────────────────────────────────────────────────────────────────
# API SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────

# Server Port (Docker: 8000)
VAPT_PORT=8000

# Database URL (SQLite in Docker)
DATABASE_URL=sqlite:///vapt.db

# API Key Secret (Generate: openssl rand -hex 32)
# CRITICAL: Change this in production!
API_KEY_SECRET=your-super-secret-key-here

# API Key Expiry (days)
API_KEY_EXPIRY_DAYS=90

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION (Docker)
# ──────────────────────────────────────────────────────────────────────────

FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
NODE_ENV=production

# ──────────────────────────────────────────────────────────────────────────
# SCAN CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────

# Target URL for scans
TARGET_URL=http://localhost:3000

# Network timeout (seconds)
# SCAN_TIMEOUT=300

# ──────────────────────────────────────────────────────────────────────────
# DOCKER COMPOSE OVERRIDES
# ──────────────────────────────────────────────────────────────────────────

# Compose project name (optional)
# COMPOSE_PROJECT_NAME=vapt-toolkit

# ──────────────────────────────────────────────────────────────────────────
# NOTIFICATION SYSTEM CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────

# SMTP Configuration (for email notifications)
# Leave empty to disable email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com

# Slack Integration (for Slack webhooks)
# Leave empty to disable Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Microsoft Teams Integration (for Teams webhooks)
# Leave empty to disable Teams notifications
# TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/YOUR/WEBHOOK/URL

# ──────────────────────────────────────────────────────────────────────────
# EXAMPLE SMTP CONFIGURATIONS
# ──────────────────────────────────────────────────────────────────────────

# Gmail (with App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM_EMAIL=your-email@gmail.com

# Outlook:
# SMTP_HOST=smtp.outlook.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@outlook.com
# SMTP_PASSWORD=your-password
# SMTP_FROM_EMAIL=your-email@outlook.com

# AWS SES (us-east-1 region):
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=verified-email@example.com

# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.your_sendgrid_api_key
# SMTP_FROM_EMAIL=your-email@example.com
